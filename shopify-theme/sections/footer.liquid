<style>
  .footer-container {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 0 2rem !important;
    width: 100% !important;
    display: block !important;
    box-sizing: border-box !important;
  }
  .footer-grid {
    display: grid !important;
    grid-template-columns: 1.5fr 1fr 1fr 1fr !important;
    gap: 3rem !important;
    padding: 4rem 0 !important;
  }
  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr !important;
      gap: 2.5rem !important;
    }
  }
  @media (max-width: 576px) {
    .footer-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>

<footer>
  <div class="container footer-container">
    <!-- Recognition Strip (Footer Integration) -->
    <div class="recognition-strip-footer">
      <h3 class="recognition-title">RECOGNIZED BY</h3>
      <div class="recognition-logos">
        <img src="{{ 'gov-login-img.png' | asset_url }}" alt="DoIT.C" class="recognition-logo-img">
        <img src="{{ 'istart_logo.png' | asset_url }}" alt="iStart Rajasthan" class="recognition-logo-img">
        <img src="{{ 'logo.png' | asset_url }}" alt="Startup India" class="recognition-logo-img">
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <img src="{{ 'full_logo.png' | asset_url }}" alt="Man Series" class="footer-logo" style="height: 36px; margin-bottom: 1.5rem;">
        <p>Redefining grooming through skin minimalism. We engineer high-performance, multi-functional formulas that deliver maximum results in fewer steps.</p>
        <div class="footer-manifesto">"Formulated for Indian Men"</div>
      </div>

      <div class="footer-links">
        <h4>Explore</h4>
        <ul>
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="/pages/series">Multi Active Series</a></li>
          <li><a href="/pages/byos">B.Y.O.S.</a></li>
          <li><a href="/pages/about">About</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/pages/faqs">FAQs</a></li>
          <li><a href="/policies/refund-policy">Returns</a></li>
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Connect</h4>
        <p><a href="mailto:support@manseries.in">support@manseries.in</a></p>
        <div class="social-icons">
          {% assign instagram_link = section.settings.instagram_url | default: 'https://www.instagram.com/manseries.in' %}
          <a href="{{ instagram_link }}" class="social-icon" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>

          {% assign facebook_link = section.settings.facebook_url | default: 'https://www.facebook.com/profile.php?id=61577519865089' %}
          <a href="{{ facebook_link }}" class="social-icon" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>

          {% assign youtube_link = section.settings.youtube_url | default: 'https://www.youtube.com/@man.series_in' %}
          <a href="{{ youtube_link }}" class="social-icon" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"></path>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon>
            </svg>
          </a>

          {% assign pinterest_link = section.settings.pinterest_url | default: 'https://www.pinterest.com/manseries01' %}
          <a href="{{ pinterest_link }}" class="social-icon" aria-label="Pinterest" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.853 0 1.267.641 1.267 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.868 3.137-4.561 0-2.387-1.715-4.052-4.163-4.052-2.838 0-4.5 2.126-4.5 4.326 0 .857.33 1.775.742 2.276a.3.3 0 0 1 .069.285c-.076.315-.244.995-.277 1.134-.044.183-.145.222-.335.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z" />
            </svg>
          </a>

          {% assign threads_link = section.settings.twitter_url | default: 'https://www.threads.net/@manseries.in' %}
          <a href="{{ threads_link }}" class="social-icon" aria-label="Threads" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M19 7.5c-1.333 -3 -3.667 -4.5 -7 -4.5c-5 0 -8 2.5 -8 9s3.5 9 8 9s7 -3 7 -5s-1 -5 -7 -5c-2.5 0 -3 1.25 -3 2.5c0 1.5 1 2.5 2.5 2.5c2.5 0 3.5 -1.5 3.5 -5s-2 -4 -3 -4s-1.833 .333 -2.5 1" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All Rights Reserved.</p>
      <p>Formulated for Indian Men · Made in India <span role="img" aria-label="India Flag">🇮🇳</span></p>
    </div>
  </div>
</footer>

<!-- Search Overlay -->
<div class="search-overlay" id="searchOverlay">
  <div class="search-container">
    <button class="search-close-btn" id="closeSearchBtn" aria-label="Close Search">&times;</button>
    <div class="search-box">
      <svg class="search-icon-inside" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" id="searchInput" placeholder="Search products, ingredients..." autocomplete="off">
    </div>
    <div class="search-results" id="searchResults"></div>
  </div>
</div>

