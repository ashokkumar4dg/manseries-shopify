<section class="science" id="science">
  <div class="bg-watermark">CLINICALLY PROVEN</div>
  <div class="container">
    <div class="science-header reveal">
      <span class="eyebrow">CLINICAL EFFICACY</span>
      <h2>
        <span class="line-normal">Clinical. Efficacy.</span>
        <span class="line-italic">Transparency</span>
      </h2>
      <p>We believe you have a right to know what you put on your skin. No hidden ingredients, no pseudoscience. Below are the verified clinical trials and formulation statistics for our Multi Active Series.
      </p>

      <!-- Core Claims Badges -->
      <div class="badge-strip">
        <div class="badge-pill">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <polyline points="9 11 11 13 15 9"></polyline>
          </svg>
          Dermatologically Tested
        </div>
        <div class="badge-pill">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          Formulated for Men
        </div>
        <div class="badge-pill">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
          Clinically Proven Actives
        </div>
      </div>
    </div>

    <div class="reports-grid reveal-stagger">

      <!-- Report 1: MS Clear Facewash -->
      <div class="science-card report-card">
        <div class="report-meta">
          <div>
            <span class="report-tag tag-clear">Product 01 / Cleanse</span>
            <h3 class="report-title">MS Clear Facewash</h3>
            <p class="report-desc">
              Engineered with 2% Salicylic Acid and Glycolic Acid to target sebum blockages, remove city tan, and clear pollutants without stripping the skin's natural lipid barrier.
            </p>
          </div>
          <div class="study-meta-details">
            <div class="meta-detail-item">
              <span class="meta-detail-label">Study Duration</span>
              <span class="meta-detail-value">4 Weeks</span>
            </div>
            <div class="meta-detail-item">
              <span class="meta-detail-label">Sample Size</span>
              <span class="meta-detail-value">50 Indian Men</span>
            </div>
            <div class="meta-detail-item">
              <span class="meta-detail-label">Skin Type</span>
              <span class="meta-detail-value">Oily to Combination</span>
            </div>
          </div>
        </div>
        <div class="report-stats">
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Sebum &amp; Excess Oil Reduction</span>
              <span class="stat-pct stat-pct-clear"><span class="counter-value" data-count-target="98">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-clear" style="--target-width: 98%"></div>
            </div>
          </div>
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Removal of Dust &amp; Urban Pollutants</span>
              <span class="stat-pct stat-pct-clear"><span class="counter-value" data-count-target="94">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-clear" style="--target-width: 94%"></div>
            </div>
          </div>
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Agreed Skin Felt Clean Without Tightness</span>
              <span class="stat-pct stat-pct-clear"><span class="counter-value" data-count-target="100">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-clear" style="--target-width: 100%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Report 2: MS Treat Serum -->
      <div class="science-card report-card">
        <div class="report-meta">
          <div>
            <span class="report-tag tag-treat">Product 02 / Treat</span>
            <h3 class="report-title">MS Treat Serum</h3>
            <p class="report-desc">
              Formulated with a synergistic matrix of 4% Niacinamide, 3% Tranexamic Acid, and 2% Alpha Arbutin. Designed to stop melanin transfer, repair acne scars, and restore compromised lipid barriers.
            </p>
          </div>
          <div class="study-meta-details">
            <div class="meta-detail-item">
              <span class="meta-detail-label">Study Duration</span>
              <span class="meta-detail-value">8 Weeks</span>
            </div>
            <div class="meta-detail-item">
              <span class="meta-detail-label">Sample Size</span>
              <span class="meta-detail-value">75 Indian Men</span>
            </div>
            <div class="meta-detail-item">
              <span class="meta-detail-label">Skin Type</span>
              <span class="meta-detail-value">All Skin Types</span>
            </div>
          </div>
        </div>
        <div class="report-stats">
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Reduction in Dark Spots &amp; Acne Scars</span>
              <span class="stat-pct stat-pct-treat"><span class="counter-value" data-count-target="92">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-treat" style="--target-width: 92%"></div>
            </div>
          </div>
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Skin Barrier Strength &amp; Hydration</span>
              <span class="stat-pct stat-pct-treat"><span class="counter-value" data-count-target="88">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-treat" style="--target-width: 88%"></div>
            </div>
          </div>
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Agreed Skin Became Smoother &amp; Less Red</span>
              <span class="stat-pct stat-pct-treat"><span class="counter-value" data-count-target="95">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-treat" style="--target-width: 95%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Report 3: MS Protect Sunscreen -->
      <div class="science-card report-card">
        <div class="report-meta">
          <div>
            <span class="report-tag tag-protect">Product 03 / Protect</span>
            <h3 class="report-title">MS Protect Sunscreen</h3>
            <p class="report-desc">
              Broad spectrum hybrid protection filters that block UVA and UVB rays. Mattifying, lightweight formula leaves zero white cast and holds up under intense heat and high sweat activities.
            </p>
          </div>
          <div class="study-meta-details">
            <div class="meta-detail-item">
              <span class="meta-detail-label">SPF Rating</span>
              <span class="meta-detail-value">SPF 50+</span>
            </div>
            <div class="meta-detail-item">
              <span class="meta-detail-label">UVA Rating</span>
              <span class="meta-detail-value">PA++++</span>
            </div>
            <div class="meta-detail-item">
              <span class="meta-detail-label">Sample Size</span>
              <span class="meta-detail-value">60 Active Men</span>
            </div>
          </div>
        </div>
        <div class="report-stats">
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Zero White Cast Verification</span>
              <span class="stat-pct stat-pct-protect"><span class="counter-value" data-count-target="100">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-protect" style="--target-width: 100%"></div>
            </div>
          </div>
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">Sweat &amp; Water Resistance</span>
              <span class="stat-pct stat-pct-protect"><span class="counter-value" data-count-target="96">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-protect" style="--target-width: 96%"></div>
            </div>
          </div>
          <div class="stat-row">
            <div class="stat-header">
              <span class="stat-label">UVA/UVB Protection Efficacy</span>
              <span class="stat-pct stat-pct-protect"><span class="counter-value" data-count-target="99">0</span>%</span>
            </div>
            <div class="science-bar">
              <div class="science-bar-fill fill-protect" style="--target-width: 99%"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Science",
  "settings": [],
  "presets": [
    {
      "name": "Home Science"
    }
  ]
}
{% endschema %}
